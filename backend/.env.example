PORT=3001

# MongoDB Connection
# 1. Default local connection (falls back to in-memory database if local MongoDB is not running):
#MONGODB_URI="mongodb://localhost:27017/grubtogo"

# 2. MongoDB Atlas (To use Atlas, uncomment and replace with your Atlas connection string):
MONGODB_URI="mongodb+srv://<username>:<password>@<cluster>.mongodb.net/grubtogo?retryWrites=true&w=majority"

# Google Gemini API Key
# Get your key from: https://aistudio.google.com/app/apikey
# Leave blank to run in mock fallback mode
GEMINI_API_KEY=""

# Cryptographic Signatures Secret (change this in production!)
JWT_SECRET="grubtogo-super-secret-key-12345"
